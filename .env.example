# Copy to .env locally if you want shell tooling to load it.
# Do not commit real API keys.

BASE_URL=http://127.0.0.1:8000/v1
API_KEY=EMPTY
MODEL=qwen3.5
RUNTIME_PROFILE=ascend_openeuler_qwen35_27b
# LLM_BASE_URL / LLM_API_KEY / LLM_MODEL_NAME remain supported aliases.
# OPENAI_BASE_URL / OPENAI_API_KEY / OPENAI_MODEL are also supported aliases.
LLM_TEMPERATURE=0
LLM_TOP_P=0.8
LLM_MAX_TOKENS=384
LLM_MAX_MODEL_LEN=4096
LLM_MAX_PROMPT_TOKENS=3400
LLM_MAX_PROMPT_CHARS=10200
LLM_REQUEST_TIMEOUT=180
LLM_ENABLE_THINKING=false
LLM_SEND_EXTRA_BODY=true

# Optional: override automatic repository-root detection.
# PCAP_LLM_ROOT=/absolute/path/to/pcap_llm_demo
