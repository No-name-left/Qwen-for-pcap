# Copy selected values to an untracked .env.local on NVIDIA Ubuntu or API clients.
RUNTIME_PROFILE=nvidia_ubuntu_online_api
LLM_BASE_URL=https://your-openai-compatible-endpoint.example/v1
LLM_MODEL_NAME=your-model-name
LLM_API_KEY=replace-locally-never-commit
LLM_ENABLE_THINKING=false
LLM_MAX_MODEL_LEN=8192
LLM_MAX_PROMPT_TOKENS=6500
LLM_MAX_PROMPT_CHARS=19500
